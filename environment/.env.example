# Copy this file to the project root as ".env" and fill in your values.
# The .env file is gitignored and never committed.

DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,djangoacadstat.vercel.app,.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://djangoacadstat.vercel.app,https://*.vercel.app

# For Vercel/Neon, set DATABASE_URL in the Vercel dashboard.
# Example:
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional local PostgreSQL values used when DATABASE_URL is not set.
POSTGRES_DB=acadstatmain
POSTGRES_USER=samir
POSTGRES_PASSWORD=pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=AcadStat <noreply@acadstat.com>
